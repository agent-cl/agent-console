{
  "name": "agent-console-monorepo",
  "version": "0.1.0",
  "private": true,
  "description": "Monorepo for agent-console CLI and landing page.",
  "workspaces": [
    "packages/*",
    "apps/*"
  ],
  "scripts": {
    "test": "npm run test --workspace agent-console",
    "pack:check": "npm run pack:check --workspace agent-console",
    "dev:landing": "npm run dev --workspace agent-console-landing",
    "deploy:landing": "npm run deploy --workspace agent-console-landing"
  },
  "engines": {
    "node": ">=20"
  }
}
